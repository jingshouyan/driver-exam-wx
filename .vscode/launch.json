{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Backend",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/backend/cmd/server",
      "cwd": "${workspaceFolder}/backend",
      "args": ["-config", "config.yaml"],
      "showLog": false
    },
    {
      "name": "Debug Backend (example config)",
      "type": "go",
