/* 全局样式 */
page {
  font-size: 16px;
  color: #333;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

.button-primary {
  width: 100%;
  padding: 14px 0;
  background-color: #07c160;
  color: #fff;
  border: none;
  border-radius: 8px;
  font-size: 18px;
  text-align: center;
}

.button-primary:active {
  background-color: #06ad56;
}

.button-secondary {
  width: 100%;
  padding: 14px 0;
  background-color: #fff;
  color: #07c160;
  border: 2px solid #07c160;
  border-radius: 8px;
  font-size: 18px;
  text-align: center;
}

.card {
  background-color: #fff;
  border-radius: 12px;
  padding: 20px;
  margin: 12px 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}
