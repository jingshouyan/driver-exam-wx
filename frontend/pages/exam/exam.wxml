<view class="page">
  <!-- 顶部信息栏 -->
  <view class="top-bar">
    <view class="progress">{{currentIndex + 1}} / {{questions.length}}</view>
    <text class="exam-badge">模拟考试</text>
  </view>

  <!-- 加载 -->
  <view class="loading" wx:if="{{!questions.length}}">
    <text>加载题目中...</text>
  </view>

  <!-- 答题区 -->
  <block wx:for="{{questions}}" wx:key="id" wx:for-index="i">
    <view class="question-area" wx:if="{{i === currentIndex && !submitted}}">
      <!-- 题目 -->
      <view class="card question-card">
        <view class="q-label">第 {{currentIndex + 1}} 题</view>
        <view class="q-text">{{item.question}}</view>
        <image class="q-pic" wx:if="{{item.pic}}" src="{{item.pic}}" mode="widthFix"></image>
      </view>

      <!-- 选项（考试模式不显示对错） -->
      <view class="options">
        <view class="option {{selectedOption === 'A' ? 'selected' : ''}}" bindtap="selectOption" data-option="A" wx:if="{{item.option1}}">
          <text class="option-label">A</text>
          <text class="option-text">{{formatOption(item.option1)}}</text>
        </view>
        <view class="option {{selectedOption === 'B' ? 'selected' : ''}}" bindtap="selectOption" data-option="B" wx:if="{{item.option2}}">
          <text class="option-label">B</text>
          <text class="option-text">{{formatOption(item.option2)}}</text>
        </view>
        <view class="option {{selectedOption === 'C' ? 'selected' : ''}}" bindtap="selectOption" data-option="C" wx:if="{{item.option3}}">
          <text class="option-label">C</text>
          <text class="option-text">{{formatOption(item.option3)}}</text>
        </view>
        <view class="option {{selectedOption === 'D' ? 'selected' : ''}}" bindtap="selectOption" data-option="D" wx:if="{{item.option4}}">
          <text class="option-label">D</text>
          <text class="option-text">{{formatOption(item.option4)}}</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="actions">
        <view class="action-btn secondary" bindtap="toggleMark">
          {{item.marked ? '✅ 已标记' : '🔖 标记'}}
        </view>
        <view class="action-btn primary" bindtap="nextQuestion">
          {{currentIndex < questions.length - 1 ? '下一题 →' : '交卷'}}
        </view>
      </view>

      <!-- 答题进度（圆点） -->
      <view class="dot-nav">
        <view class="dot {{answers[i] !== '' ? 'done' : ''}} {{i === currentIndex ? 'current' : ''}}" 
              wx:for="{{questions}}" wx:key="id" wx:for-index="idx"
              bindtap="jumpTo" data-index="{{idx}}"></view>
      </view>
    </view>
  </block>

  <!-- 交卷结果 -->
  <view class="result-area" wx:if="{{submitted}}">
    <view class="card result-card">
      <text class="result-icon">📋</text>
      <text class="result-title">考试完成</text>
      <view class="score">{{score}}<text class="score-unit">分</text></view>
      <view class="stat-row">
        <text>共 {{questions.length}} 题</text>
        <text>答对 {{correctCount}} 题</text>
        <text>答错 {{wrongCount}} 题</text>
      </view>
    </view>

    <!-- 错题列表 -->
    <view class="wrong-list" wx:if="{{wrongList.length > 0}}">
      <text class="section-title">答错题目（{{wrongList.length}} 题）</text>
      <view class="wrong-item" wx:for="{{wrongList}}" wx:key="id" bindtap="goPractice">
        <text class="wrong-q">{{item.question}}</text>
        <text class="wrong-answer">正确答案：{{item.answer}}</text>
      </view>
    </view>

    <view class="action-btn primary" bindtap="goHome">返回首页</view>
  </view>

</view>
