.page {
  min-height: 100vh;
  padding-bottom: 40px;
}

/* 顶部栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  background-color: #fff;
  border-bottom: 1px solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.progress {
  font-size: 14px;
  color: #666;
}

.exam-badge {
  font-size: 12px;
  color: #ff6a00;
  background-color: #fff0e0;
  padding: 2px 8px;
  border-radius: 4px;
}

/* 加载 */
.loading {
  text-align: center;
  padding: 60px 0;
  color: #999;
}

/* 题目 */
.question-card {
  margin-top: 12px;
}

.q-label {
  font-size: 13px;
  color: #ff6a00;
  margin-bottom: 8px;
}

.q-text {
  font-size: 18px;
  line-height: 1.6;
  color: #333;
}

.q-pic {
  width: 100%;
  margin-top: 12px;
  border-radius: 8px;
}

/* 选项 */
.options {
  margin: 0 16px;
}

.option {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  margin-bottom: 10px;
  background-color: #fff;
  border-radius: 10px;
  border: 2px solid #e8e8e8;
}

.option.selected {
  border-color: #ff6a00;
  background-color: #fff8f0;
}

.option.correct {
  border-color: #07c160;
  background-color: #f0fff5;
}

.option.wrong {
  border-color: #ee0a24;
  background-color: #fff0f0;
}

.option.reveal {
  border-color: #07c160;
  background-color: #f0fff5;
  opacity: 0.8;
}

.option-label {
  width: 28px;
  height: 28px;
  line-height: 28px;
  text-align: center;
  border-radius: 50%;
  background-color: #f0f0f0;
  font-weight: 600;
  font-size: 14px;
  color: #666;
  margin-right: 12px;
  flex-shrink: 0;
}

.option.selected .option-label {
  background-color: #ff6a00;
  color: #fff;
}

.option.correct .option-label,
.option.reveal .option-label {
  background-color: #07c160;
  color: #fff;
}

.option.wrong .option-label {
  background-color: #ee0a24;
  color: #fff;
}

.option-text {
  font-size: 16px;
  color: #333;
  line-height: 1.4;
}

/* 操作 */
.actions {
  display: flex;
  gap: 12px;
  margin: 16px;
}

.action-btn {
  flex: 1;
  padding: 14px;
  text-align: center;
  border-radius: 10px;
  font-size: 16px;
  font-weight: 500;
}

.action-btn.primary {
  background-color: #ff6a00;
  color: #fff;
}

.action-btn.secondary {
  background-color: #fff;
  color: #666;
  border: 1px solid #ddd;
}

/* 答题进度点 */
.dot-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  justify-content: center;
  margin: 0 16px;
}

.dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background-color: #ddd;
}

.dot.current {
  background-color: #ff6a00;
  width: 12px;
  height: 12px;
}

.dot.done {
  background-color: #07c160;
}

/* 结果页 */
.result-area {
  padding: 40px 16px;
}

.result-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 20px;
  margin-bottom: 20px;
}

.result-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.result-title {
  font-size: 22px;
  font-weight: 600;
  color: #333;
}

.score {
  font-size: 48px;
  font-weight: 700;
  color: #ff6a00;
  margin: 16px 0;
}

.score-unit {
  font-size: 18px;
  font-weight: 400;
}

.stat-row {
  display: flex;
  gap: 16px;
  font-size: 14px;
  color: #666;
}

/* 错题列表 */
.section-title {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 12px;
}

.wrong-list {
  margin-bottom: 20px;
}

.wrong-item {
  padding: 12px 16px;
  background-color: #fff;
  border-radius: 10px;
  margin-bottom: 8px;
}

.wrong-q {
  display: block;
  font-size: 14px;
  color: #333;
  margin-bottom: 4px;
}

.wrong-answer {
  display: block;
  font-size: 13px;
  color: #07c160;
  margin-top: 6px;
}

.wrong-opts {
  margin-top: 8px;
}

.wrong-opts .option {
  margin-bottom: 6px;
  padding: 8px 12px;
  font-size: 14px;
}

.wrong-opts .option-label {
  width: 22px;
  height: 22px;
  line-height: 22px;
  font-size: 12px;
  margin-right: 8px;
}

.timer {
  font-size: 16px;
  font-weight: 700;
  color: #333;
  font-variant-numeric: tabular-nums;
}

.timer-warn {
  color: #ee0a24;
}

