.page {
  min-height: 100vh;
  padding-bottom: 40px;
}

.top-bar {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  background-color: #fff;
  border-bottom: 1px solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
  gap: 8px;
}

.progress {
  font-size: 14px;
  color: #666;
}

.timer {
  font-size: 14px;
  color: #999;
  margin-left: auto;
}

.top-stats {
  display: flex;
  gap: 8px;
  font-size: 13px;
  margin-left: auto;
}

.stat-correct {
  color: #07c160;
  font-weight: 600;
}

.stat-wrong {
  color: #ee0a24;
  font-weight: 600;
}

.exam-badge {
  font-size: 12px;
  color: #07c160;
  padding: 2px 8px;
  background-color: #f0fff5;
  border-radius: 10px;
}

.loading {
  text-align: center;
  padding: 60px 0;
  color: #999;
}

.question-card {
  margin-top: 12px;
}

.q-label {
  font-size: 13px;
  color: #07c160;
  margin-bottom: 8px;
}

.q-text {
  font-size: 18px;
  line-height: 1.6;
  color: #333;
}

.q-pic-wrap {
  width: 100%;
  height: 200px;
  border-radius: 8px;
  margin-top: 12px;
  background-color: #f8f8f8;
}

.q-pic {
  width: 100%;
  height: 200px;
}

.options {
  margin: 0 16px;
}

.option {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  margin-bottom: 10px;
  background-color: #fff;
  border-radius: 10px;
  border: 2px solid #e8e8e8;
}

.option.correct {
  border-color: #07c160;
  background-color: #f0fff5;
}

.option.wrong {
  border-color: #ee0a24;
  background-color: #fff0f0;
}

.option.reveal {
  border-color: #07c160;
  background-color: #f0fff5;
  opacity: 0.8;
}

.option-label {
  width: 28px;
  height: 28px;
  line-height: 28px;
  text-align: center;
  border-radius: 50%;
  background-color: #f0f0f0;
  font-weight: 600;
  font-size: 14px;
  color: #666;
  margin-right: 12px;
  flex-shrink: 0;
}

.option.correct .option-label,
.option.reveal .option-label {
  background-color: #07c160;
  color: #fff;
}

.option.wrong .option-label {
  background-color: #ee0a24;
  color: #fff;
}

.option-text {
  font-size: 16px;
  color: #333;
  line-height: 1.4;
}

.feedback {
  margin: 0 16px;
  padding: 16px;
  background-color: #fff;
  border-radius: 12px;
}

.result-badge {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 8px;
}

.result-badge.correct { color: #07c160; }
.result-badge.wrong { color: #ee0a24; }

.correct-answer {
  font-size: 14px;
  color: #07c160;
  margin-bottom: 8px;
}

.explain {
  font-size: 14px;
  color: #666;
  line-height: 1.6;
  padding: 12px;
  background-color: #f8f8f8;
  border-radius: 8px;
  margin-top: 8px;
}

.tip {
  font-size: 13px;
  color: #07c160;
  margin-top: 8px;
  line-height: 1.5;
}

.tip-label {
  font-weight: 600;
}

.actions {
  display: flex;
  gap: 12px;
  margin: 16px;
}

.action-btn {
  flex: 1;
  padding: 14px;
  text-align: center;
  border-radius: 10px;
  font-size: 16px;
  font-weight: 500;
}

.action-btn.primary {
  background-color: #07c160;
  color: #fff;
}

.action-btn.secondary {
  background-color: #fff;
  color: #666;
  border: 1px solid #ddd;
}

.result-area {
  padding: 40px 16px;
}

.result-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 20px;
  margin-bottom: 20px;
}

.result-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.result-title {
  font-size: 22px;
  font-weight: 600;
  color: #333;
}

.score {
  font-size: 36px;
  font-weight: 700;
  color: #07c160;
  margin: 16px 0;
}

.score-unit {
  font-size: 18px;
  font-weight: 400;
  color: #999;
}

.correct-rate {
  font-size: 16px;
  color: #07c160;
  margin-bottom: 8px;
}

.stat-row {
  display: flex;
  gap: 16px;
  font-size: 14px;
  color: #666;
}

.wrong-list {
  margin-bottom: 20px;
}

.section-title {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 12px;
}

.wrong-item {
  padding: 12px 16px;
  background-color: #fff;
  border-radius: 10px;
  margin-bottom: 8px;
}

.wrong-q {
  display: block;
  font-size: 14px;
  color: #333;
  margin-bottom: 4px;
}

.card {
  background-color: #fff;
  border-radius: 12px;
  padding: 16px;
  margin: 0 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
