<view class="page" bindtouchstart="handleTouchStart" bindtouchend="handleTouchEnd">
  <!-- 顶部信息栏 -->
  <view class="top-bar">
    <view class="progress">{{currentIndex + 1}} / {{questions.length}}</view>
  </view>

  <!-- 上次练习结果 -->
  <view class="last-result" wx:if="{{lastResult && !isComplete}}">
    <text class="last-label">累计：</text>
    <text class="last-rate">正确率 {{lastResult.correctRate}}%</text>
    <text class="last-sub">（答对 {{lastResult.correctCount}} 题）</text>
    <view class="clear-btn" catchtap="clearProgress">清除进度</view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{!questions.length}}">
    <text>加载题目中...</text>
  </view>

  <!-- 答题区 -->
  <block wx:for="{{questions}}" wx:key="id" wx:for-index="i">
    <view class="question-area" wx:if="{{i === currentIndex}}">
      <!-- 题目 -->
      <view class="card question-card">
        <view class="q-label">第 {{currentIndex + 1}} 题</view>
        <view class="q-text">{{item.question}}</view>
        <image class="q-pic" wx:if="{{item.pic}}" src="{{item.picData || ''}}" mode="widthFix"></image>
      </view>

      <!-- 选项 -->
      <view class="options">
        <view class="option {{optClassA}}" bindtap="selectOption" data-option="A" wx:if="{{item.option1}}">
          <text class="option-label">A</text>
          <text class="option-text">{{item.option1}}</text>
        </view>
        <view class="option {{optClassB}}" bindtap="selectOption" data-option="B" wx:if="{{item.option2}}">
          <text class="option-label">B</text>
          <text class="option-text">{{item.option2}}</text>
        </view>
        <view class="option {{optClassC}}" bindtap="selectOption" data-option="C" wx:if="{{item.option3}}">
          <text class="option-label">C</text>
          <text class="option-text">{{item.option3}}</text>
        </view>
        <view class="option {{optClassD}}" bindtap="selectOption" data-option="D" wx:if="{{item.option4}}">
          <text class="option-label">D</text>
          <text class="option-text">{{item.option4}}</text>
        </view>
      </view>

      <!-- 答题反馈 -->
      <view class="feedback" wx:if="{{answered}}">
        <view class="result-badge {{isCorrect ? 'correct' : 'wrong'}}">
          {{isCorrect ? '✅ 回答正确' : '❌ 回答错误'}}
        </view>
        <view class="correct-answer">正确答案：{{item.answerText}}</view>
        <view class="explain" wx:if="{{item.explain}}">{{item.explain}}</view>
      </view>

      <!-- 操作按钮 -->
      <view class="actions" wx:if="{{answered}}">
        <view class="action-btn secondary" bindtap="toggleMark">
          {{item.marked ? '✅ 已标记' : '🔖 标记回顾'}}
        </view>
        <view class="action-btn primary" bindtap="nextQuestion">
          {{currentIndex < questions.length - 1 ? '下一题 →' : '完成练习'}}
        </view>
      </view>
    </view>
  </block>

  <!-- 完成页 -->
  <view class="complete-area" wx:if="{{isComplete}}">
    <view class="card complete-card">
      <text class="complete-icon">🎉</text>
      <text class="complete-title">练习完成</text>
      <text class="complete-stat">共 {{questions.length}} 题</text>
      <view class="complete-bar">
        <view class="bar-correct" style="width: {{correctRate}}%"></view>
      </view>
      <text class="complete-rate">正确率 {{correctRate}}%</text>
    </view>

    <!-- 错题回顾 -->
    <view class="wrong-list" wx:if="{{wrongList.length > 0}}">
      <text class="section-title">答错回顾（{{wrongList.length}} 题）</text>
      <view class="wrong-item" wx:for="{{wrongList}}" wx:key="id">
        <text class="wrong-q">{{item.question}}</text>
        <view class="wrong-opts">
          <view class="option {{wrongOptClass(item, 'A')}}" wx:if="{{item.option1}}">
            <text class="option-label">A</text>
            <text class="option-text">{{item.option1}}</text>
          </view>
          <view class="option {{wrongOptClass(item, 'B')}}" wx:if="{{item.option2}}">
            <text class="option-label">B</text>
            <text class="option-text">{{item.option2}}</text>
          </view>
          <view class="option {{wrongOptClass(item, 'C')}}" wx:if="{{item.option3}}">
            <text class="option-label">C</text>
            <text class="option-text">{{item.option3}}</text>
          </view>
          <view class="option {{wrongOptClass(item, 'D')}}" wx:if="{{item.option4}}">
            <text class="option-label">D</text>
            <text class="option-text">{{item.option4}}</text>
          </view>
        </view>
        <text class="wrong-answer">正确答案：{{item.answerText}}</text>
      </view>
    </view>

    <view class="action-btn primary" bindtap="goHome">返回首页</view>
  </view>

</view>
