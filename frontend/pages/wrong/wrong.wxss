.page {
  min-height: 100vh;
  padding-bottom: 40px;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  padding: 12px 16px;
  background-color: #fff;
  gap: 8px;
  border-bottom: 1px solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.filter-tab {
  padding: 6px 20px;
  border-radius: 16px;
  font-size: 14px;
  color: #666;
  background-color: #f5f5f5;
}

.filter-tab.active {
  background-color: #07c160;
  color: #fff;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80px 0;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.empty-text {
  font-size: 16px;
  color: #999;
}

/* 错题列表 */
.wrong-list {
  padding: 12px 16px;
}

.wrong-card {
  background-color: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.wrong-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.wrong-subject {
  font-size: 12px;
  color: #999;
  background-color: #f5f5f5;
  padding: 2px 8px;
  border-radius: 4px;
}

.wrong-mark {
  font-size: 12px;
  color: #ff6a00;
}

.wrong-question {
  display: block;
  font-size: 16px;
  line-height: 1.5;
  color: #333;
  margin-bottom: 8px;
}

.wrong-answer {
  font-size: 14px;
  color: #999;
}

.answer-text {
  color: #07c160;
  font-weight: 600;
}

/* 展开详情 */
.detail {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid #eee;
}

.detail-option {
  display: flex;
  align-items: center;
  padding: 8px 0;
  font-size: 14px;
}

.opt-label {
  width: 24px;
  height: 24px;
  line-height: 24px;
  text-align: center;
  border-radius: 50%;
  background-color: #f0f0f0;
  font-size: 12px;
  font-weight: 600;
  color: #666;
  margin-right: 10px;
  flex-shrink: 0;
}

.opt-label.correct {
  background-color: #07c160;
  color: #fff;
}

.opt-text {
  color: #333;
}

.detail-explain {
  font-size: 14px;
  color: #666;
  line-height: 1.6;
  padding: 12px;
  background-color: #f8f8f8;
  border-radius: 8px;
  margin-top: 8px;
}

.explain-label {
  font-weight: 600;
  color: #333;
}

.detail-actions {
  margin-top: 12px;
}

.detail-btn {
  text-align: center;
  padding: 10px;
  font-size: 14px;
  color: #ee0a24;
  border: 1px solid #ee0a24;
  border-radius: 8px;
}

/* 清空 */
.clear-bar {
  margin: 0 16px 20px;
}

.clear-btn {
  text-align: center;
  padding: 12px;
  font-size: 14px;
  color: #999;
  border: 1px solid #ddd;
  border-radius: 8px;
}
